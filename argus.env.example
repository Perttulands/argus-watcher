# Argus environment configuration

# Telegram alerting (optional — Argus works without it, just won't send alerts)
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Relay integration (optional — fallback file is used if Relay is unavailable)
ARGUS_RELAY_ENABLED=true
ARGUS_RELAY_BIN=$HOME/go/bin/relay
ARGUS_RELAY_TO=athena
ARGUS_RELAY_FROM=argus
ARGUS_RELAY_TIMEOUT=5
ARGUS_STATE_DIR=$HOME/tools/argus/state
ARGUS_INCIDENTS_FILE=$ARGUS_STATE_DIR/incidents.jsonl
ARGUS_OBSERVATIONS_FILE=$ARGUS_STATE_DIR/observations.md
ARGUS_RELAY_FALLBACK_FILE=$ARGUS_STATE_DIR/relay-fallback.jsonl
ARGUS_RELAY_OBSERVATIONS_FALLBACK_FILE=$ARGUS_STATE_DIR/relay-observations-fallback.jsonl
ARGUS_RELAY_SUMMARY_ENABLED=true
ARGUS_RELAY_SUMMARY_FALLBACK_FILE=$ARGUS_STATE_DIR/relay-summary-fallback.jsonl
ARGUS_RELAY_DRAIN_MAX_ITEMS=100
ARGUS_OBSERVATIONS_LINES=50
ARGUS_DASHBOARD_URL=

# Alert deduplication
ARGUS_DEDUP_WINDOW=3600

# Disk cleanup action
ARGUS_DISK_CLEAN_MAX_AGE_DAYS=7

# Restart backoff
ARGUS_RESTART_BACKOFF_SECOND_DELAY=60
ARGUS_RESTART_BACKOFF_THIRD_DELAY=300
ARGUS_RESTART_COOLDOWN_SECONDS=3600
